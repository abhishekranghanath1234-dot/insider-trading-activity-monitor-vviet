import pandas as pd
import numpy as np
from sklearn.ensemble import IsolationForest
from sklearn.preprocessing import StandardScaler
import joblib

# --------------------------------------------------
# LOAD DATA
# --------------------------------------------------

df = pd.read_csv("data/insider_transactions_data.csv")

# --------------------------------------------------
# FEATURE SELECTION
# --------------------------------------------------

features = [
    "Shares",
    "TransactionValue",
    "Price",
    "OwnershipPercent"
]

# Convert to numeric
for col in features:
    if col in df.columns:
        df[col] = pd.to_numeric(df[col], errors="coerce")

df = df.dropna(subset=features)

# --------------------------------------------------
# SCALE DATA
# --------------------------------------------------

scaler = StandardScaler()
X = scaler.fit_transform(df[features])

# --------------------------------------------------
# TRAIN ANOMALY MODEL
# --------------------------------------------------

model = IsolationForest(
    n_estimators=200,
    contamination=0.05,
    random_state=42
)

model.fit(X)

# --------------------------------------------------
# ADD SCORES (OPTIONAL DEBUG)
# --------------------------------------------------

df["AnomalyScore"] = model.decision_function(X)
df["AnomalyFlag"] = model.predict(X)

df["RiskLabel"] = np.where(
    df["AnomalyFlag"] == -1,
    "Suspicious",
    "Normal"
)

# --------------------------------------------------
# SAVE MODEL
# --------------------------------------------------

joblib.dump(model, "models/anomaly_model.pkl")
joblib.dump(scaler, "models/anomaly_scaler.pkl")
joblib.dump(features, "models/anomaly_features.pkl")

print("Anomaly model saved successfully ✔")
